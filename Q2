#include <cstdio>
#include <vector>

using namespace std;


const int MAXN = 10000001;
int factors[MAXN];
int power_of_two[32];

void precompute() {
    for (int i = 2; i < MAXN; ++i) {
        if (factors[i] == 0) { // i is prime
            for (int j = i; j < MAXN; j += i) {
                factors[j]++;
            }
        }
    }
    

    power_of_two[0] = 1;
    for (int i = 1; i < 30; ++i) {
        power_of_two[i] = power_of_two[i - 1] << 1;
    }
}


inline void solve() {
    int n;
    if (scanf("%d", &n) != 1) return;
    
    if (n == 1) {
        printf("1\n");
        return;
    }
    
    
    printf("%d\n", power_of_two[factors[n]]);
}

int main() {
    precompute();
    
    int t;
    if (scanf("%d", &t) != 1) return 0;
    while (t--) {
        solve();
    }
    
    return 0;
}

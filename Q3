#include <iostream>

using namespace std;


long long count_odds(long long k) {
    if (k < 1) return 0;
    return (k + 1) / 2;
}

int main() {
   
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    long long L, R;
    if (!(cin >> L >> R)) return 0;

    long long odd_count = count_odds(R) - count_odds(L - 1);

   
    if (odd_count % 2 == 0) {
        cout << "even" << endl;
    } else {
        cout << "odd" << endl;
    }

    return 0;
}
